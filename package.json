{
  "name": "jungle-diff-timer",
  "productName": "Jungle Diff Timer",
  "version": "1.0.0",
  "description": "Overlay de timers da selva para League of Legends",
  "main": "main.js",
  "author": "Marlon Tavares",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mhtdev.jungledifftimer",
    "files": ["main.js", "preload.js", "app/**/*"],
    "directories": { "buildResources": "build" },
    "win": {
      "icon": "build/icon.ico",
      "target": [{ "target": "portable", "arch": ["x64"] }]
    },
    "portable": {
      "artifactName": "JungleDiffTimer.exe"
    }
  }
}
